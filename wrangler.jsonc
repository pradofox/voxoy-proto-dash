{
	"compatibility_date": "2026-05-02",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "voxoy-proto-dash",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "voxoy.sopadeletras.art",
			"custom_domain": true
		}
	]
}
